{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    "noEmit": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",

    "lib": ["ES2022", "DOM"],

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,

    "baseUrl": "."
  },
  "include": ["src"]
}